# AI プロバイダー設定（groq, gemini, openrouter, grok のいずれか）
# groq / gemini / openrouter は無料、grok（xAI）は有料
AI_PROVIDER=groq

# Groq API キー（無料・高レート上限。https://console.groq.com/keys で取得）
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini API キー（無料枠あり）
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API キー（無料プランで動作するが混雑しやすい）
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# xAI Grok API キー（有料。AI_PROVIDER=grok の場合、または全無料枠失敗時のフォールバックに使用）
GROK_API_KEY=your_grok_api_key_here
GROK_MODEL=grok-4-fast

# Podcast 公開 URL（GitHub Pages の URL）
PODCAST_BASE_URL=https://your-username.github.io/idol-podcast
PODCAST_TITLE=ライブアイドルデイリー
PODCAST_DESCRIPTION=ライブアイドルシーンの最新情報を毎朝お届けする音声ニュースです。
PODCAST_AUTHOR=your-name
PODCAST_EMAIL=your-email@example.com
PODCAST_IMAGE_URL=https://your-username.github.io/idol-podcast/artwork.png

# TTS 設定
TTS_RATE=+10%
TTS_VOLUME=+0%

# ログレベル
LOG_LEVEL=INFO
