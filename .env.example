# AI プロバイダー設定（openrouter または gemini）
AI_PROVIDER=openrouter

# OpenRouter API キー（無料プランで動作）
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Google Gemini API キー（AI_PROVIDER=gemini の場合に使用）
GEMINI_API_KEY=your_gemini_api_key_here

# Podcast 公開 URL（GitHub Pages の URL）
PODCAST_BASE_URL=https://your-username.github.io/idol-podcast
PODCAST_TITLE=ライブアイドルデイリー
PODCAST_DESCRIPTION=ライブアイドルシーンの最新情報を毎朝お届けする音声ニュースです。
PODCAST_AUTHOR=your-name
PODCAST_EMAIL=your-email@example.com
PODCAST_IMAGE_URL=https://your-username.github.io/idol-podcast/artwork.png

# TTS 設定
TTS_RATE=+10%
TTS_VOLUME=+0%

# ログレベル
LOG_LEVEL=INFO
